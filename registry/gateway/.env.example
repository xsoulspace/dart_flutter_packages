HOST=0.0.0.0
PORT=8080
CACHE_DIR=.cache/registry-gateway
CACHE_TTL_SECONDS=300
UPSTREAM_TIMEOUT_SECONDS=10
UPSTREAM_RETRY_COUNT=1
UPSTREAM_RETRY_BACKOFF_SECONDS=0.2
REGISTRY_INDEX_BASE_URL=https://raw.githubusercontent.com/xsoulspace/dart_flutter_packages/registry-index
GITHUB_REPOSITORY=xsoulspace/dart_flutter_packages
ARCHIVE_REDIRECT_TEMPLATE=https://github.com/{github_repo}/releases/download/{tag}/{asset}
