default:
    @just --list

generate:
    @echo "No code generation required for wrapper package"

generate-check:
    @echo "No generated wrapper files to check"

analyze:
    dart analyze

test:
    dart test

test-example device='macos':
    (cd example && flutter test integration_test -d {{device}})

verify:
    just generate-check
    just analyze
    just test
